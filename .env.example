###############################################
#  Nexus Sentinel - environment configuration
#  Copy to .env and fill in your values
###############################################

# Required - Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Required - Your Telegram user/chat ID (get it from @userinfobot)
ADMIN_CHAT_ID=your_chat_id_here

# Optional - Full path to the nexus-network binary
NEXUS_PATH=/root/.nexus/bin/nexus-network

# Optional - How often to check node status (seconds, default: 30)
CHECK_INTERVAL_SECONDS=30

# Optional - Cooldown between restart attempts per node (seconds, default: 600)
COOLDOWN_SECONDS=600

# Optional - Directory for persistent data: nodes list, settings, logs (default: data/)
# DATA_DIR=data
